# Auto detect text files and perform LF normalization
* text=auto

# C++ source files: enforce LF for cross-platform compatibility
*.cpp text eol=lf
*.h   text eol=lf
*.hpp text eol=lf
*.c   text eol=lf

# Build system files: enforce LF
*.cmake      text eol=lf
CMakeLists.txt text eol=lf
*.py         text eol=lf

# Windows batch files: keep CRLF for compatibility
*.bat text eol=crlf
*.cmd text eol=crlf

# Config / documentation files: enforce LF
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini  text eol=lf

# Git / template files: enforce LF
.gitignore               text eol=lf
*.template               text eol=lf
*.txt.in                 text eol=lf

# Binary files: do not modify line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.exe  binary
*.dll  binary
*.lib  binary
*.a    binary
*.so   binary
*.dylib binary
