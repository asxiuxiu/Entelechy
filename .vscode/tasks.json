                    "--config",
                    "configs/engine_only.json",
                    "--debug",
                    "--build"
                ]
            },
            "group": "build",
            "problemMatcher": [
                "$msCompile"
            ],
            "detail": "完整流程：生成 → 配置 → 编译 Debug（仅引擎）"
        },
