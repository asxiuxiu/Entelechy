{
    "version": "2.0.0",
    "tasks": [
        // ============================================================
        // 环境初始化：创建项目本地 venv 并安装 pinned conan
        // ============================================================
        {
            "label": "Init: Setup Python Environment",
            "type": "shell",
            "windows": {
                "command": "python",
                "args": [
                    "${workspaceFolder}/scripts/tools/setup_env.py"
                ]
            },
            "linux": {
                "command": "python3",
                "args": [
                    "${workspaceFolder}/scripts/tools/setup_env.py"
                ]
            },
            "osx": {
                "command": "python3",
                "args": [
                    "${workspaceFolder}/scripts/tools/setup_env.py"
                ]
            },
            "group": "build",
            "problemMatcher": [],
            "detail": "创建 .venv 并按 configs/environment.json 安装指定版本的 Conan、CMake 等依赖，初始化项目级 .conan_home"
        },
