            "label": "Build: Engine Only (Debug)",
            "dependsOn": "Init: Setup Python Environment",
            "type": "shell",
            "windows": {
                "command": "python",
                "args": [
                    "${workspaceFolder}/scripts/build/build.py",
                    "--config",
                    "configs/engine_only.json",
                    "--debug",
                    "--build"
                ]
            },
            "linux": {
