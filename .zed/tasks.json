[
    {
        "label": "Init: Setup Python Environment",
        "command": "python3",
        "args": [
            "scripts/tools/setup_env.py"
        ],
        "cwd": "$ZED_WORKTREE_ROOT",
        "reveal": "always",
        "hide": "never",
        "use_new_terminal": false,
        "allow_concurrent_runs": false,
        "shell": "system"
    },
    {
        "label": "Build: Engine Only (Debug)",
        "command": "python3",
        "args": [
            "scripts/build/build.py",
            "--config",
            "configs/engine_only.json",
            "--debug",
            "--build"
        ],
        "cwd": "$ZED_WORKTREE_ROOT",
        "reveal": "always",
        "hide": "never",
        "use_new_terminal": false,
        "allow_concurrent_runs": false,
        "shell": "system"
    },
